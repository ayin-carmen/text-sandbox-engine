{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/text-sandbox-engine/entity.schema.json",
  "title": "Entity",
  "type": "object",
  "required": ["id", "type", "components"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "components": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object"
      }
    },
    "metadata": {
      "type": "object",
      "default": {}
    }
  },
  "additionalProperties": false
}
